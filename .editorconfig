root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{kt,kts}]
indent_size = 2
max_line_length = 120
ktlint_code_style = ktlint_official
# The project uses PascalCase for top-level Compose constants and backticked test names; keep those.
ktlint_standard_property-naming = disabled
ktlint_standard_function-naming = disabled
# Keep short accessor chains (libs.versions.x.get().toInt()) on one line.
ktlint_standard_chain-method-continuation = disabled
# Let `val x = Foo(...)` and signatures that fit stay as written, rather than force-wrapping them.
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_function-signature = disabled

[*.{yml,yaml,toml}]
indent_size = 2
